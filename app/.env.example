# AI Provider
ARTICLE_CHECK_AI_PROVIDER=dify

# Dify API
DIFY_BASE_URL=http://localhost/v1
DIFY_API_KEY=app-your-dify-api-key-here
DIFY_APP_TYPE=workflow
DIFY_RESPONSE_MODE=blocking
DIFY_WORKFLOW_QUERY_KEY=query
DIFY_INPUTS_JSON={}
ARTICLE_CHECK_DIFY_BASE_URL=http://localhost/v1
ARTICLE_CHECK_DIFY_API_KEY=
ARTICLE_CHECK_DIFY_APP_MODE=workflow
ARTICLE_CHECK_DIFY_DOCUMENT_READ_API_KEY=
ARTICLE_CHECK_DIFY_FORMAT_REVIEW_API_KEY=
ARTICLE_CHECK_DIFY_REFERENCE_VERIFY_API_KEY=
ARTICLE_CHECK_DIFY_HALLUCINATION_REVIEW_API_KEY=
ARTICLE_CHECK_DIFY_REPORT_GENERATION_API_KEY=
ARTICLE_CHECK_DIFY_REPORT_QA_API_KEY=

# Optional DeepSeek fallback
DEEPSEEK_API_KEY=sk-your-key-here

# 项目
ARTICLE_CHECK_ROOT=

# 可选: 搜索 API (serper)
SERPER_API_KEY=

# 可选: 平台认证（默认本地关闭）
ARTICLE_CHECK_PLATFORM_AUTH_ENABLED=false
ARTICLE_CHECK_PLATFORM_AUTH_MODE=prod_api_idp
ARTICLE_CHECK_PLATFORM_AUTH_API_BASE=/prod-api
ARTICLE_CHECK_PLATFORM_AUTH_CALLBACK_PATH=/auth/login
ARTICLE_CHECK_PLATFORM_AUTH_STORAGE_PREFIX=article_check_platform_

# 可选: 本地 Docker 验证时转发平台认证网关
PLATFORM_AUTH_PROXY_TARGET=http://platform-auth-gateway.example.internal
PLATFORM_AUTH_PROXY_HOST_HEADER=platform-auth-gateway.example.internal
