# ==========================================================
# Article Check — Docker 部署环境变量模板
# 根据 PPT 规范: API Key 通过环境变量注入，不硬编码
# 复制为 .env 后填入真实值:
#   cp .env.docker .env
# ==========================================================

# ─── AI Provider（平台部署默认走 Dify）──────────────────
ARTICLE_CHECK_AI_PROVIDER=dify

# ─── Dify API（必填）─────────────────────────────────────
# 自托管 Dify 示例: http://host.docker.internal/v1
# SaaS Dify 示例: https://api.dify.ai/v1
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-your-dify-api-key-here

# Dify 应用类型: chat 或 workflow
DIFY_APP_TYPE=workflow

# blocking 更适合当前后端代理模式
DIFY_RESPONSE_MODE=blocking

# 若 Dify 使用 workflow，可指定接收 query 的输入变量名
DIFY_WORKFLOW_QUERY_KEY=query

# Dify 应用的固定 inputs(JSON 字符串)
DIFY_INPUTS_JSON={}

# 可选：为不同工作流单独配置 Key（为空则回退到 DIFY_API_KEY）
ARTICLE_CHECK_DIFY_BASE_URL=https://api.dify.ai/v1
ARTICLE_CHECK_DIFY_API_KEY=
ARTICLE_CHECK_DIFY_APP_MODE=workflow
ARTICLE_CHECK_DIFY_DOCUMENT_READ_BASE_URL=
ARTICLE_CHECK_DIFY_DOCUMENT_READ_API_KEY=
ARTICLE_CHECK_DIFY_DOCUMENT_READ_MODE=
ARTICLE_CHECK_DIFY_DOCUMENT_READ_APP_REFERENCE=https://udify.app/workflow/dbvfR3MQYfPPlHkJ
ARTICLE_CHECK_DIFY_COMPONENT_CLASSIFICATION_BASE_URL=
ARTICLE_CHECK_DIFY_COMPONENT_CLASSIFICATION_API_KEY=
ARTICLE_CHECK_DIFY_COMPONENT_CLASSIFICATION_MODE=
ARTICLE_CHECK_DIFY_COMPONENT_CLASSIFICATION_APP_REFERENCE=https://udify.app/workflow/SNjqCn9fZbIzG81x
ARTICLE_CHECK_DIFY_FORMAT_REVIEW_BASE_URL=
ARTICLE_CHECK_DIFY_FORMAT_REVIEW_API_KEY=
ARTICLE_CHECK_DIFY_FORMAT_REVIEW_MODE=
ARTICLE_CHECK_DIFY_FORMAT_REVIEW_APP_REFERENCE=https://udify.app/workflow/qqiz0GZOcbetK35r
ARTICLE_CHECK_DIFY_REFERENCE_VERIFY_BASE_URL=
ARTICLE_CHECK_DIFY_REFERENCE_VERIFY_API_KEY=
ARTICLE_CHECK_DIFY_REFERENCE_VERIFY_MODE=
ARTICLE_CHECK_DIFY_REFERENCE_VERIFY_APP_REFERENCE=https://udify.app/workflow/xOFCPi2VzmpI6fv1
ARTICLE_CHECK_DIFY_HALLUCINATION_REVIEW_BASE_URL=
ARTICLE_CHECK_DIFY_HALLUCINATION_REVIEW_API_KEY=
ARTICLE_CHECK_DIFY_HALLUCINATION_REVIEW_MODE=
ARTICLE_CHECK_DIFY_HALLUCINATION_REVIEW_APP_REFERENCE=https://udify.app/workflow/nVRkoJaJkj4MeQQT
ARTICLE_CHECK_DIFY_REPORT_GENERATION_BASE_URL=
ARTICLE_CHECK_DIFY_REPORT_GENERATION_API_KEY=
ARTICLE_CHECK_DIFY_REPORT_GENERATION_MODE=
ARTICLE_CHECK_DIFY_REPORT_GENERATION_APP_REFERENCE=https://udify.app/workflow/Skfvt4amRApAvTTX
ARTICLE_CHECK_DIFY_REPORT_QA_BASE_URL=
ARTICLE_CHECK_DIFY_REPORT_QA_API_KEY=
ARTICLE_CHECK_DIFY_REPORT_QA_MODE=
ARTICLE_CHECK_DIFY_REPORT_QA_APP_REFERENCE=https://udify.app/workflow/Jmem7t2HPs6j4xA3

# ─── DeepSeek API（可选兜底）─────────────────────────────
DEEPSEEK_API_KEY=

# ─── Nginx 端口 ──────────────────────────────────────────
# PPT 规范: 宿主机 80(3000) 端口映射容器内 web 服务端口
# 建议 3000 避免与已有服务冲突
NGINX_PORT=3000

# ─── 可选: 搜索 API ──────────────────────────────────────
# 从 https://serper.dev 获取
SERPER_API_KEY=

# ─── 其他配置 ────────────────────────────────────────────
# PDF 解析增强
ARTICLE_CHECK_GROBID_ENABLED=false
ARTICLE_CHECK_GROBID_BASE_URL=http://grobid:8070

# ─── 平台认证（默认本地关闭）─────────────────────────────
ARTICLE_CHECK_PLATFORM_AUTH_ENABLED=false
ARTICLE_CHECK_PLATFORM_AUTH_MODE=legacy_oauth
ARTICLE_CHECK_PLATFORM_AUTH_API_BASE=/prod-api
ARTICLE_CHECK_PLATFORM_AUTH_HOST=http://124.71.226.114:8444
ARTICLE_CHECK_PLATFORM_AUTH_CALLBACK_PATH=/auth/login
ARTICLE_CHECK_PLATFORM_AUTH_STORAGE_PREFIX=article_check_platform_
ARTICLE_CHECK_PLATFORM_AUTH_DEBUG=false

# 本地 Docker 验证官方认证链路时，配置平台网关地址
PLATFORM_AUTH_PROXY_TARGET=http://124.71.226.114:8444
PLATFORM_AUTH_PROXY_HOST_HEADER=124.71.226.114:8444

# TZ=Asia/Shanghai
